{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://brox.sh/schemas/skill.schema.json",
  "title": "Brox Skill Manifest",
  "type": "object",
  "required": ["name", "version", "description", "license", "author"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9][a-z0-9-]{1,38}/[a-z0-9][a-z0-9-]{1,49}$",
      "description": "Scoped skill name: @scope/skill-name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z-.]+)?(?:\\+[0-9A-Za-z-.]+)?$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier"
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "entry": {
      "type": "string",
      "default": "SKILL.md"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["claude", "cursor", "cline", "continue", "codex", "any"]
      },
      "default": ["claude"]
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["fs:read", "fs:write", "network", "exec", "secrets"]
      },
      "uniqueItems": true
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 10
    },
    "dependencies": {
      "type": "object",
      "patternProperties": {
        "^@[a-z0-9][a-z0-9-]{1,38}/[a-z0-9][a-z0-9-]{1,49}$": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
